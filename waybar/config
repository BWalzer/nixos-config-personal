[
  {
    "layer": "top",
    "position": "top",
    "mode": "dock",
    "exclusive": true,
    "passthrough": false,
    "reload_style_on_change": true,

    "modules-left": ["group/leaf-inverse"],
    "modules-center": ["group/pill-in#center"],
    "modules-right": ["group/leaf"],

    "group/leaf-inverse": {
      "orientation": "inherit",
      "modules": ["hyprland/workspaces", "wlr/taskbar"]
    },

    "group/pill-in#center": {
      "orientation": "inherit",
      "modules": ["idle_inhibitor", "clock"]
    },

    "group/leaf": {
      "orientation": "inherit",
      "modules": [
        "privacy",
        "backlight",
        "tray",
        "network#bandwidthUpBytes",
        "network#bandwidthDownBytes",
        "bluetooth",
        "pulseaudio",
        "pulseaudio#microphone",
        "battery",
        "power-profiles-daemon"
      ]
    },

    "hyprland/workspaces": {
      "all-outputs": true,
      "active-only": false,
      "on-click": "activate",
      "disable-scroll": false,
      "on-scroll-up": "hyprctl dispatch workspace -1",
      "on-scroll-down": "hyprctl dispatch workspace +1",
      "persistent-workspaces": {}
    },

    "wlr/taskbar": {
      "all-outputs": true,
      "active-first": false,
      "markup": true,
      "format": "{icon}",
      "spacing": 20,
      "tooltip-format": "{title} | {app_id}",
      "on-click": "activate",
      "on-click-right": "fullscreen",
      "on-click-middle": "close",
      "ignore-list": [""]
    },

    "clock": {
      "format": "{:%I:%M %p}",
      "format-alt": "{:%R  %d·%m·%y}",
      "tooltip-format": "<span>{calendar}</span>",
      "calendar": {
        "mode": "month",
        "mode-mon-col": 3,
        "on-scroll": 1,
        "on-click-right": "mode",
        "format": {
          "months": "<span color='#ffead3'><b>{}</b></span>",
          "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
          "today": "<span color='#ff6699'><b>{}</b></span>"
        }
      },
      "actions": {
        "on-click-right": "mode",
        "on-click-forward": "tz_up",
        "on-click-backward": "tz_down",
        "on-scroll-up": "shift_up",
        "on-scroll-down": "shift_down"
      }
    },

    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "\udb80\udd76",
        "deactivated": "\udb81\udeca"
      },
      "tooltip": true,
      "tooltip-format-activated": "Caffeine Mode Active\nPrevents system from going to sleep",
      "tooltip-format-deactivated": "Caffeine Mode Inactive\nSystem will follow normal power settings"
    },

    "privacy": {
      "icon-spacing": 5,
      "transition-duration": 250,
      "modules": [
        { "type": "screenshare", "tooltip": true },
        { "type": "audio-in", "tooltip": true }
      ],
      "ignore-monitor": true
    },

    "backlight": {
      "format": "{icon} {percent}%",
      "format-icons": ["", "", "", "", "", "", "", "", ""],
      "on-scroll-up": "brightnessctl set +1%",
      "on-scroll-down": "brightnessctl set 1%-",
      "min-length": 6,
      "tooltip": true,
      "tooltip-format": "Backlight: {icon} {percent}%"
    },

    "tray": {
      "spacing": 5
    },

    "network#bandwidthUpBytes": {
      "format": "󰕹 {bandwidthUpBytes}",
      "format-disconnected": "󰤮 ",
      "interval": 2,
      "tooltip": false
    },

    "network#bandwidthDownBytes": {
      "format": "󰇚 {bandwidthDownBytes}",
      "format-disconnected": "󰤮 ",
      "interval": 2,
      "tooltip": true,
      "tooltip-format": "Network: {essid}\nIP: {ipaddr}\nInterface: {ifname}"
    },

    "bluetooth": {
      "format": "",
      "format-disabled": "",
      "format-connected": " {num_connections}",
      "format-connected-battery": "{icon} {num_connections}",
      "format-icons": ["󰥇", "󰤾", "󰤿", "󰥀", "󰥁", "󰥂", "󰥃", "󰥄", "󰥅", "󰥆", "󰥈"],
      "tooltip-format": "{controller_alias}\n{num_connections} connected",
      "tooltip-format-connected": "{controller_alias}\n{num_connections} connected\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}"
    },

    "pulseaudio": {
      "format": "{icon} {volume}",
      "format-muted": "婢",
      "on-click": "pavucontrol",
      "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
      "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
      "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
      "tooltip-format": "{icon} {desc} // {volume}%",
      "scroll-step": 5,
      "format-icons": {
        "headphone": "",
        "hands-free": "",
        "headset": "",
        "phone": "",
        "portable": "",
        "car": "",
        "default": ["", "", ""]
      }
    },

    "pulseaudio#microphone": {
      "format": "{format_source}",
      "format-source": " {volume}",
      "format-source-muted": "",
      "on-click": "pavucontrol",
      "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
      "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%+",
      "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%-",
      "tooltip-format": "Mic: {source_desc} // {source_volume}%",
      "scroll-step": 5
    },

    "battery": {
      "format": "{icon} {capacity}%",
      "format-charging": " {capacity}%",
      "format-plugged": " {capacity}%",
      "format-alt": "{time} {icon}",
      "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"]
    },

    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "",
        "performance": "",
        "balanced": "",
        "power-saver": ""
      }
    }
  }
]
